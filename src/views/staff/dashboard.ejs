<div class="row align-items-center g-3 mt-4 mb-4">
  <div class="col-md-8">
    <h1 class="h3 mb-1">Staff Dashboard</h1>
    <p class="text-secondary mb-0">Track active orders, complete service, and manage table occupancy.</p>
  </div>
</div>

<div class="row g-4">
  <div class="col-xl-8">
    <div class="panel-card section-card mb-4">
      <div class="section-head">
        <div>
          <h2 class="h4 mb-1">Pending Orders</h2>
          <p class="text-secondary mb-0">Orders that still need preparation, pickup, or delivery action.</p>
        </div>
      </div>
      <% if (!pendingOrders.length) { %>
        <div class="empty-state">
          <h3>No pending orders</h3>
          <p>New and active orders will appear here.</p>
        </div>
      <% } %>
      <% pendingOrders.forEach((order) => { %>
        <% const readyAt = order.estimatedReadyAt ? new Date(order.estimatedReadyAt) : null; %>
        <% const deadlineAt = order.pickupDeadline ? new Date(order.pickupDeadline) : null; %>
        <div class="order-card mb-3">
          <div class="d-flex justify-content-between align-items-start gap-3">
            <div>
              <strong><%= order.user?.name || "Unknown" %></strong>
              <div class="small text-secondary"><%= order.user?.email || "" %></div>
              <div class="small mt-2"><%= order.items.map((item) => `${item.name} x${item.quantity}`).join(", ") %></div>
            </div>
            <div class="text-end">
              <span class="badge text-bg-secondary text-capitalize"><%= order.status %></span>
              <div class="small mt-2">Rs. <%= order.totalAmount %></div>
            </div>
          </div>

          <div class="row g-3 mt-1">
            <div class="col-md-4">
              <div class="rule-box h-100">
                <div class="countdown-label">Order Type</div>
                <strong class="text-capitalize"><%= order.orderType %></strong>
                <% if (order.orderType === "dine-in") { %>
                  <div class="small text-secondary mt-2">Table: <%= order.table?.tableNumber || "Not linked" %></div>
                  <div class="small text-secondary">Table status: <%= order.table?.status || "Unknown" %></div>
                <% } else if (order.orderType === "delivery") { %>
                  <div class="small text-secondary mt-2">Location: <%= order.deliveryLocation || "Not set" %></div>
                <% } else { %>
                  <div class="small text-secondary mt-2">Pickup from counter</div>
                <% } %>
              </div>
            </div>
            <div class="col-md-4">
              <div class="rule-box h-100">
                <div class="countdown-label">Ready ETA</div>
                <% if (order.status === "ready") { %>
                  <strong>Ready now</strong>
                <% } else if (readyAt && !Number.isNaN(readyAt.getTime())) { %>
                  <strong data-countdown="<%= readyAt.toISOString() %>"><%= readyAt.toLocaleTimeString() %></strong>
                <% } else { %>
                  <strong>Pending</strong>
                <% } %>
              </div>
            </div>
            <div class="col-md-4">
              <div class="rule-box h-100">
                <div class="countdown-label">Pickup / Service</div>
                <% if (deadlineAt && !Number.isNaN(deadlineAt.getTime())) { %>
                  <strong data-countdown="<%= deadlineAt.toISOString() %>"><%= deadlineAt.toLocaleTimeString() %></strong>
                <% } else { %>
                  <strong>Starts at ready</strong>
                <% } %>
              </div>
            </div>
          </div>

          <form action="/staff/orders/<%= order._id %>/status" method="POST" class="row g-2 align-items-end mt-3">
            <div class="col-md-8">
              <label class="form-label">Update Status</label>
              <select class="form-select form-control-campus" name="status">
                <% ["placed","preparing","ready","delivered","cancelled","penalised"].forEach((status) => { %>
                  <option value="<%= status %>" <%= order.status === status ? 'selected' : '' %>><%= status %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-4">
              <button class="btn btn-campus-primary w-100" type="submit">Save</button>
            </div>
          </form>
        </div>
      <% }) %>
    </div>

    <div class="panel-card section-card">
      <div class="section-head">
        <div>
          <h2 class="h4 mb-1">Past Orders</h2>
          <p class="text-secondary mb-0">Completed, cancelled, and penalised orders.</p>
        </div>
      </div>
      <% if (!pastOrders.length) { %>
        <div class="empty-state">
          <h3>No past orders</h3>
          <p>Completed orders will appear here.</p>
        </div>
      <% } %>
      <% pastOrders.forEach((order) => { %>
        <div class="order-card mb-3">
          <div class="d-flex justify-content-between align-items-start gap-3">
            <div>
              <strong><%= order.user?.name || "Unknown" %></strong>
              <div class="small text-secondary"><%= order.user?.email || "" %></div>
              <div class="small mt-2"><%= order.items.map((item) => `${item.name} x${item.quantity}`).join(", ") %></div>
            </div>
            <div class="text-end">
              <span class="badge <%= order.status === 'penalised' ? 'text-bg-danger' : 'bg-dark-subtle text-dark' %> text-capitalize">
                <%= order.status === "penalised" ? "cancelled / penalised" : order.status %>
              </span>
              <div class="small mt-2">Rs. <%= order.totalAmount %></div>
            </div>
          </div>
          <div class="small text-secondary mt-3">
            <% if (order.orderType === "dine-in") { %>
              Dine-in | Table <%= order.table?.tableNumber || "Not linked" %> | Table status <%= order.table?.status || "Unknown" %>
            <% } else if (order.orderType === "delivery") { %>
              Delivery | <%= order.deliveryLocation || "Location not set" %>
            <% } else { %>
              Takeaway | Pickup counter
            <% } %>
          </div>
        </div>
      <% }) %>
    </div>
  </div>

  <div class="col-xl-4">
    <div class="panel-card section-card">
      <div class="section-head">
        <div>
          <h2 class="h4 mb-1">Tables</h2>
          <p class="text-secondary mb-0">Monitor reservation and occupancy state.</p>
        </div>
      </div>
      <% tables.forEach((table) => { %>
        <div class="order-card mb-3">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <strong><%= table.tableNumber %></strong>
              <div class="small text-secondary"><%= table.seats %> seats | <%= table.reservedBy?.name || "No reservation" %></div>
              <% if (table.status === "reserved" && table.currentOrder) { %>
                <div class="small text-secondary">Held for linked dine-in order</div>
              <% } else if (table.status === "reserved" && table.reservationWindow?.end) { %>
                <div class="small text-secondary">Expires in <span data-countdown="<%= new Date(table.reservationWindow.end).toISOString() %>">01:00</span></div>
              <% } %>
            </div>
            <span class="badge rounded-pill text-bg-dark"><%= table.status %></span>
          </div>
          <form action="/staff/tables/<%= table._id %>/status" method="POST" class="mt-3 d-flex gap-2">
            <select class="form-select form-select-sm" name="status">
              <% ["available","reserved","occupied"].forEach((status) => { %>
                <option value="<%= status %>" <%= table.status === status ? 'selected' : '' %>><%= status %></option>
              <% }) %>
            </select>
            <button class="btn btn-campus-secondary btn-sm" type="submit">Update</button>
          </form>
        </div>
      <% }) %>
    </div>
  </div>
</div>
