<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mt-4 mb-4">
  <div>
    <h1 class="h3 mb-1">Review Cart</h1>
    <p class="text-secondary mb-0">Confirm the order details before placing it.</p>
  </div>
  <a href="/consumer/dashboard" class="btn btn-outline-secondary">Back</a>
</div>

<div class="row g-4">
  <div class="col-lg-8">
    <div class="panel-card section-card">
      <h2 class="h4 mb-3">Cart Items</h2>
      <% cart.items.forEach((item) => { %>
        <div class="order-card">
          <div class="d-flex justify-content-between align-items-start gap-3">
            <div>
              <strong><%= item.name %></strong>
              <div class="small text-secondary mt-1">Quantity: <%= item.quantity %></div>
            </div>
            <span class="price-tag">Rs. <%= item.quantity * item.unitPrice %></span>
          </div>
        </div>
      <% }) %>
    </div>
  </div>

  <div class="col-lg-4">
    <div class="panel-card section-card">
      <h2 class="h4 mb-3">Order Summary</h2>
      <div class="rule-box mb-3">
        <div class="d-flex justify-content-between">
          <span>Order Type</span>
          <strong class="text-capitalize"><%= cart.orderType %></strong>
        </div>
        <div class="d-flex justify-content-between mt-2">
          <span>Items</span>
          <strong><%= cart.items.length %></strong>
        </div>
        <div class="d-flex justify-content-between mt-2">
          <span>Food total</span>
          <strong>Rs. <%= cart.subtotalAmount %></strong>
        </div>
        <% if (cart.carriedPenaltyAmount) { %>
          <div class="d-flex justify-content-between mt-2 text-danger">
            <span>Outstanding penalty added</span>
            <strong>Rs. <%= cart.carriedPenaltyAmount %></strong>
          </div>
        <% } %>
        <div class="d-flex justify-content-between mt-2">
          <span>Payable total</span>
          <strong>Rs. <%= cart.totalAmount %></strong>
        </div>
      </div>

      <% if (cart.orderType === "dine-in") { %>
        <div class="dynamic-order-note mb-3">
          Assigned table: <strong><%= table?.tableNumber || cart.tableNumber %></strong>
        </div>
      <% } %>

      <% if (cart.orderType === "delivery") { %>
        <div class="dynamic-order-note mb-3">
          Delivery location: <strong><%= cart.deliveryLocation %></strong>
        </div>
      <% } %>

      <% if (cart.orderType === "takeaway") { %>
        <div class="dynamic-order-note mb-3">
          Pickup will happen from the designated collection counter once staff marks the order ready.
        </div>
      <% } %>

      <div class="rule-box mb-4">
        Collection penalty after ready: <strong>double the order amount</strong>
      </div>
      <form action="/consumer/orders/confirm" method="POST" class="d-grid gap-2">
        <button type="submit" class="btn btn-campus-primary">Confirm to Place Order</button>
      </form>
      <form action="/consumer/cart/cancel" method="POST" class="d-grid mt-2">
        <button type="submit" class="btn btn-outline-secondary">Cancel</button>
      </form>
    </div>
  </div>
</div>
