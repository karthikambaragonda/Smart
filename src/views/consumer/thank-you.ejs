<div class="row justify-content-center mt-5">
  <div class="col-lg-7">
    <div class="panel-card text-center p-5">
      <p class="eyebrow mb-2">Order Completed</p>
      <h1 class="h2 mb-3">Thank you for ordering</h1>
      <p class="text-secondary mb-4">
        Your order has been delivered successfully.
      </p>
      <div class="rule-box mb-4">
        <div><strong>Order total:</strong> Rs. <%= order.totalAmount %></div>
        <div class="small text-secondary mt-2 text-capitalize"><%= order.orderType %> | <%= order.serviceLocation || order.deliveryLocation || "Campus service" %></div>
      </div>
      <% if (order.orderType === "dine-in") { %>
        <div class="alert alert-warning mb-4">
          Please vacate the table as fast as possible so others can be seated. Click the button below before leaving to free the table.
        </div>
        <% if (order.table && order.table.status !== "available") { %>
          <form action="/consumer/orders/<%= order._id %>/free-table" method="POST" class="mb-3">
            <button type="submit" class="btn btn-campus-secondary">Free the Table</button>
          </form>
        <% } %>
      <% } %>
      <div class="d-flex justify-content-center gap-2 flex-wrap">
        <a href="/consumer/dashboard" class="btn btn-campus-primary">Back to Dashboard</a>
        <a href="/consumer/orders" class="btn btn-outline-secondary">View Orders</a>
      </div>
    </div>
  </div>
</div>
