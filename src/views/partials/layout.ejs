<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> | Smart Campus Food Ordering</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body data-role="<%= currentUser?.role || '' %>" data-user-id="<%= currentUser?._id || '' %>">
    <%- include("navbar") %>
    <div id="notificationHost" class="notification-host" aria-live="polite" aria-atomic="true"></div>
    <main class="page-shell">
      <div class="container campus-container py-4">
        <%- include("flash") %>
        <%- body %>
      </div>
    </main>
    <footer class="campus-footer">
      <div class="container campus-container d-flex flex-column flex-md-row justify-content-between gap-2">
        <span>Smart Campus Food Ordering System</span>
        <span>Consumer, staff, and manager workflows in one live platform</span>
      </div>
    </footer>
    <script src="/socket.io/socket.io.js"></script>
    <script src="/js/app.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
  </html>
